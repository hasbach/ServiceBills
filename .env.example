# servicesBills environment — copy to .env and fill in. NEVER commit real secrets.

# --- Core (required) ---
JWT_SECRET_KEY=change-me-to-a-64-char-random-hex   # python -c "import secrets;print(secrets.token_hex(32))"
FERNET_KEY=change-me                                # python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# Postgres in prod. Managed hosts' postgres:// URLs are auto-normalized.
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/servicesbills
# Public URL of the app (used in verification/reset/billing links). No trailing slash.
APP_BASE_URL=https://app.yourdomain.com
# Comma-separated browser origins allowed to call the API (usually just APP_BASE_URL).
CORS_ORIGINS=https://app.yourdomain.com

# --- Email (signup verification + password reset) ---
# "sendgrid" is recommended in prod: many hosts (Render included) block outbound
# SMTP ports, but SendGrid's HTTP API rides over normal HTTPS. "smtp" is available
# for hosts that do allow it; "console" (dev, logs only) is the default.
MAIL_BACKEND=sendgrid
SENDGRID_API_KEY=SG....
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

# --- Object storage (uploads) ---
STORAGE_BACKEND=s3                # "local" (dev disk) or "s3" (S3 / Cloudflare R2)
STORAGE_BUCKET=servicesbills-uploads
STORAGE_PREFIX=uploads
AWS_REGION=auto                   # "auto" for Cloudflare R2
S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com   # R2 endpoint; omit for AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Stripe billing ---
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from the Stripe webhook endpoint you create
STRIPE_PRICE_PRO=price_...        # the Pro plan's Stripe Price ID

# --- Scheduler ---
# Run the background jobs in EXACTLY ONE process. Web tier: RUN_SCHEDULER=0.
# One dedicated worker (or a single-worker instance): RUN_SCHEDULER=1.
RUN_SCHEDULER=0
